{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/license/layout,_N_T_/license/page,_N_T_/license"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/license/__PAGE__",
    "/license",
    "/_index",
    "/_head"
  ]
}